# Omnidimension web widget — must be present when you run `npm run build` / `vite build`
# (CI: set as a secret env var). Copy to `.env.local` for local dev; never commit real keys.
VITE_OMNIDIM_WIDGET_KEY=

# Omnidimension REST API (dashboard API key) — used only by scripts, not the browser.
# Example: python scripts/omnidimension_create_lexi_agent.py
# OMNIDIM_API_KEY=
