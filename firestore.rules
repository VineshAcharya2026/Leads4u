rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // 0. Global Catch-All Deny
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Global Helpers
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function getEmail() { return request.auth.token.email; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // -------------------------------------------------------------------------
    // 1. Users Collection
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId &&
                      incoming().role in ['customer', 'provider'] &&
                      incoming().uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin()) &&
                      (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber']));
    }

    // -------------------------------------------------------------------------
    // 2. Provider Profiles
    // -------------------------------------------------------------------------
    match /profiles/{userId} {
      allow get: if true; // Publicly viewable
      allow list: if true; // Publicly searchable
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // 3. Leads Collection
    // -------------------------------------------------------------------------
    match /leads/{leadId} {
      allow get: if isSignedIn() && (request.auth.uid == existing().customerId || isAdmin());
      allow list: if isSignedIn() && (resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == existing().customerId || isAdmin());
      allow delete: if isAdmin();

      // Subcollection for assignments
      match /assignments/{providerId} {
        allow get: if isSignedIn() && (request.auth.uid == providerId || request.auth.uid == get(/databases/$(database)/documents/leads/$(leadId)).data.customerId || isAdmin());
        allow list: if isSignedIn();
        allow create, update: if isAdmin() || (isSignedIn() && request.auth.uid == providerId);
      }
    }

    // -------------------------------------------------------------------------
    // 4. Subscriptions
    // -------------------------------------------------------------------------
    match /subscriptions/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin(); // Managed via server-side (Express + Stripe Webhooks)
    }

    // -------------------------------------------------------------------------
    // 5. Reviews
    // -------------------------------------------------------------------------
    match /reviews/{reviewId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.auth.uid == incoming().customerId;
      allow update: if isSignedIn() && request.auth.uid == existing().customerId;
      allow delete: if isAdmin();
    }
  }
}
